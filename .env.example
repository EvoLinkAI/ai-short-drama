# AIDrama Studio — Environment Configuration
# https://github.com/EvoLinkAI/ai-short-drama
#
# Copy this file to .env and fill in the values for your environment.

# ==================== Database ====================
# Local dev mode: docker-compose.yml maps MySQL to host port 13306
# Docker container mode: docker-compose.yml overrides this automatically
DATABASE_URL="mysql://root:aidrama-studio123@localhost:13306/aidrama-studio"

# ==================== Storage ====================
# evolink: EvoLink Files API (images) + local filesystem (audio/video)
# minio: S3-compatible object storage
# local: local file storage (development only)
STORAGE_TYPE=evolink

# EvoLink Files API (STORAGE_TYPE=evolink)
# Images → https://files-api.evolink.ai (public URLs, 72h TTL)
# Audio/video → local filesystem fallback (UPLOAD_DIR)
# API key auto-reads from user's Settings. Optional override:
# EVOLINK_FILES_API_KEY=

# MinIO / S3-compatible storage config (STORAGE_TYPE=minio)
# MINIO_ENDPOINT=http://localhost:19000
# MINIO_REGION=us-east-1
# MINIO_BUCKET=aidrama-studio
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_FORCE_PATH_STYLE=true

# ==================== Auth ====================
# Local dev mode (option 3): use http://localhost:3000
# Docker container mode (options 1 & 2): injected by docker-compose.yml as http://localhost:13000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=please-change-this-to-a-random-string

# ==================== Internal App URL ====================
# Used for server-side internal fetch of this app's APIs / files only.
# Local dev mode usually matches NEXTAUTH_URL; Docker mode injected by docker-compose.yml as http://127.0.0.1:3000
INTERNAL_APP_URL=http://127.0.0.1:3000

# ==================== Internal Secrets ====================
CRON_SECRET=please-change-this-cron-secret
INTERNAL_TASK_TOKEN=please-change-this-task-token
API_ENCRYPTION_KEY=please-change-this-encryption-key

# ==================== Redis ====================
# Local dev mode: docker-compose.yml maps Redis to host port 16379
# Docker container mode: docker-compose.yml overrides this automatically
REDIS_HOST=127.0.0.1
REDIS_PORT=16379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=

# ==================== Worker Config ====================
WATCHDOG_INTERVAL_MS=25000
TASK_HEARTBEAT_TIMEOUT_MS=120000
QUEUE_CONCURRENCY_IMAGE=40
QUEUE_CONCURRENCY_VIDEO=50
QUEUE_CONCURRENCY_VOICE=20
QUEUE_CONCURRENCY_TEXT=40

# ==================== Billing ====================
BILLING_MODE=OFF

# ==================== Bull Board ====================
BULL_BOARD_HOST=0.0.0.0
BULL_BOARD_PORT=3010
BULL_BOARD_BASE_PATH=/admin/queues
BULL_BOARD_USER=
BULL_BOARD_PASSWORD=

# ==================== Logging ====================
LOG_UNIFIED_ENABLED=true
LOG_LEVEL=ERROR
LOG_FORMAT=json
LOG_DEBUG_ENABLED=false
LOG_AUDIT_ENABLED=true
LOG_SERVICE=aidrama-studio
LOG_REDACT_KEYS=password,token,apiKey,apikey,authorization,cookie,secret,access_token,refresh_token

# ==================== LLM Streaming ====================
LLM_STREAM_EPHEMERAL_ENABLED=true
